{
  "name": "hosted-service",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.6.0"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "card": "node content/images/src/gen-card.mjs",
    "publish-litmus": "NODE_OPTIONS= pnpm --filter @polygraph/runner publish-litmus",
    "serve": "NODE_OPTIONS= pnpm --filter @polygraph/runner serve",
    "worker": "NODE_OPTIONS= pnpm --filter @polygraph/runner worker"
  }
}
