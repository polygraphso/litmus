# @polygraphso/litmus — example configuration.
#
# This repository is PUBLIC-BY-DESIGN. This file documents the SHAPE of the
# config the harness understands — placeholders only. Copy it to `.env` (which is
# gitignored) and fill real values there. NEVER put a real secret in this file.
#
# Everything here is OPTIONAL: `polygraphso-litmus litmus <target>` grades a server
# fully offline with no config at all. The variables below only enable extra paths.

# --- Pinning + mint hand-off (optional) ---------------------------------------
# Set POLYGRAPH_API_URL to enable pinning the evidence bundle and printing a mint
# deep-link. Without it, runs stay fully offline.
POLYGRAPH_API_URL=
# Bearer token for grading a remote (HTTP) target that requires auth.
LITMUS_BEARER=

# --- Sandbox / runtime knobs (optional) ---------------------------------------
# Container runtime for the C-02 egress sandbox (default: runsc/gVisor in prod).
LITMUS_DOCKER_RUNTIME=
# Set to 1 to run the Docker-dependent tests locally.
LITMUS_DOCKER_TESTS=
# Set to 1 to `docker build --pull` when (re)building the sandbox image.
LITMUS_DOCKER_BUILD_PULL=
# Stdio isolation mode for locally-launched MCP servers.
LITMUS_STDIO_ISOLATION=
# SSRF guard: set to 1 ONLY for local dev against a private/loopback target.
POLYGRAPH_ALLOW_PRIVATE_TARGETS=

# --- Network / proof reading (optional) ---------------------------------------
# Which network to read attestations from, and the EAS schema UID + RPC URLs.
NEXT_PUBLIC_POLYGRAPH_NETWORK=
NEXT_PUBLIC_EAS_SCHEMA_UID=
BASE_MAINNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=

# --- Advanced: EAS schema registration script only ----------------------------
# NOT needed to grade servers, and NOT used by the CLI/MCP/library. Read only by
# the one-time operator script that registers the EAS schema on a network
# (packages/onchain/src/scripts/register-schema.ts). Minting and IPFS pinning are
# done by the web app, not this package. Treat any real value as a live secret —
# NEVER commit it.
MINTER_PRIVATE_KEY=            # funded EOA, used only by register-schema.ts
